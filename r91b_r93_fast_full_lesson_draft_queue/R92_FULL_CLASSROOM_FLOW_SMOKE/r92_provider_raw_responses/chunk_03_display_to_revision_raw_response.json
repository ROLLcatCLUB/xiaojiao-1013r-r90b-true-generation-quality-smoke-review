  "lesson_design_mode": "profile_targeted_classroom_flow_smoke",
  "intent_summary": "为《色彩的渐变》展示交流与评价修订环节生成 6 条 classroom_flow 字段候选，承接 R91B 的端色—中间色—过渡—层次主线，把展示、说明、同伴互评、学生修订、教师观察、作品证据落到具体课堂动作。",
  "lesson_logic_brief": {
    "inherited_unit_context_summary": "第二单元《多彩的世界》从自然、教材和生活中的色彩变化进入渐变表达，本课为 2-1《色彩的渐变》。",
    "core_learning_problem": "学生能看到颜色深浅、浓淡和鲜灰差异，但容易把渐变理解为几种颜色排上去，缺少对端色、中间色、过渡方向与层次的明确意识。",
    "student_starting_point": "三年级学生能区分明暗与冷暖，但不会把观察组织成端色与中间色，也不会用方向词描述过渡。",
    "target_shift": "从看到几种颜色，转到能指认端色与中间色、能用方向说明过渡、能在作品中安排至少三段层次，并能据此互评与修订。",
    "lesson_focus_question": "怎样从一种端色自然过渡到另一种端色，中间要安排几段层次？",
    "visual_language_use": "围绕端色、中间色、过渡、方向、层次五个词展开，配合纸条色阶和分层小稿。",
    "teaching_route": [
      "观察天空与色环，端色—中间色—过渡—层次四词建语汇",
      "教师示范端色到中间色的湿接过渡并外化语言",
      "学生在分层小稿上创作至少三段层次并标注",
      "小组互贴展示，按端色、中间色、过渡三问自述",
      "同伴互评聚焦过渡方向与层次段数",
      "学生据互评意见修订一件作品并留存证据"
    ],
    "evidence_plan": [
      "分层小稿上端色位、中间色位与方向箭头",
      "色阶纸条或圆内三段层次作品",
      "背面写出的端色与中间色词条",
      "同伴互评三问的口头说明",
      "修订前后同一作品的照片或二图对比"
    ],
    "risk_points": [
      "展示变成看热闹，没有自述与互评",
      "互评只评好看不好看，不指向过渡与层次",
      "修订环节学生不知改什么，缺明确观察点",
      "作品证据只拍照不附文字说明"
    ],
    "source_basis": [
