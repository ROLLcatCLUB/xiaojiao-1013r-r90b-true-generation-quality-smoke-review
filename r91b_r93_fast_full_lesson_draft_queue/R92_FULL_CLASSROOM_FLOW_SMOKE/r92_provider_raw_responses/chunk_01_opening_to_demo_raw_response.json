  "lesson_design_mode": "profile_targeted_classroom_flow_smoke",
  "intent_summary": "为《色彩的渐变》第一段（导入至示范）生成九个课堂流程候选，落到核心问题、视觉对象、情境脚手架、观察探问、视觉语汇、示范动作、示范语言和技法焦点。",
  "lesson_logic_brief": {
    "inherited_unit_context_summary": "第二单元《多彩的世界》从自然、教材和生活中的色彩变化进入渐变表达，本课2-1《色彩的渐变》是开篇。",
    "core_learning_problem": "学生能看到颜色深浅、浓淡和鲜灰差异，但常把渐变当成几种颜色排在一起，缺少对端色—中间色—过渡方向与层次的连贯理解。",
    "student_starting_point": "能看出颜色不一样，但不会指认端色、不会描述中间色，也不习惯用方向与层次解释画面。",
    "target_shift": "从看颜色转向看过渡，从随意涂色转向按端色—中间色—方向做有层次的作品，并能用作品证据和口头说明支持判断。",
    "lesson_focus_question": "怎样用两个端色和几段中间色做出有方向、有层次的色彩渐变？",
    "visual_language_use": "围绕端色、中间色、过渡方向、层次、湿接叠色五个词展开，配合天空图、色环、纸条和小稿做证据。",
    "teaching_route": [
      "导入用生活里日出日落天空的深浅变化引出渐变",
      "观察环节用天空图让学生圈出端色与中间色",
      "示范环节用纸条把端色到中间色的过渡外化为五段色阶",
      "创作环节用分层小稿约束端色—中间色—方向",
      "展示评价环节按端色、过渡、说明三项互评"
    ],
    "evidence_plan": [
      "天空图上学生圈画的端色与中间色笔迹",
      "教师五条渐变纸条作为示范作品证据",
      "学生分层小稿与正面作品对照",
      "作品背面口述端色与中间色、方向的录音或文字记录"
    ],
    "risk_points": [
      "导入只问颜色多不多，引不到端色与方向",
      "示范只涂一排颜色，没体现湿接与中间色",
      "创作任务过散，学生仍只涂几种颜色不连成渐变"
    ],
    "source_basis": [
      "active_profile",
      "lesson_case"
    ],
